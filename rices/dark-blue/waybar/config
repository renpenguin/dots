{
    "layer": "top", // Waybar at top layer
    "position": "top",
    "height": 30,
    // "width": 1280,
    "spacing": 4,

    "modules-left": ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "gamemode", "cpu", "memory", "wireplumber", "network", "battery"],

    // Modules configuration
    "hyprland/workspaces": {
      "all-outputs": true,
      "format": "{icon}",
      "format-icons": {
        "1": "у°Ҳ№",
        "2": "оһ•",
        "3": "пҚҜ",
        "4": "пҮҝ",
        "5": "пҖҒ",
        "6": "у°Ү®",
        "urgent": "пҒӘ",
        "default": "пӢҗ"
      }
    },
    "hyprland/submap": {
      "format": "{} ", // Padding
      "on-click": "hyprctl dispatch submap reset",
    },
    "clock": {
        "interval": 60,
        // "timezone": "Europe/London",
        "format": "{:%R пҖ—  %A %d/%m/%y} п„і",
        "tooltip": false,
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 10
    },
    "gamemode": {
        "format": "{glyph}",
        "format-alt": "{count} {glyph}",
        "glyph": "пһі",
        "hide-not-running": true,
        "use-icon": true,
        "icon-name": "input-gaming-symbolic",
        "icon-spacing": 4,
        "tooltip": true,
        "tooltip-format": "Games running: {count}"
    },
    "cpu": {
        "interval": 2,
        "format": "{usage}% пӢӣ",
        "tooltip": false
    },
    "memory": {
        "interval": 2,
        "format": "{percentage}% пғү",
        "tooltip-format": "{used}/{total} used"
    },
    "wireplumber": {
        "format": "{volume}% {icon}",
        "format-muted": "о»Ё",
        "format-icons": ["пҖҰ", "пҖ§", "пҖЁ", "пҖЁ"],
        "on-click": "~/.config/hypr/scripts/audio.sh"
    },
    "network": {
        "format-wifi": "{icon}",
        "format-ethernet": "{ipaddr}/{cidr} пһ–",
        "tooltip-format": "{ifname} via {gwaddr} пһ–",
        "format-linked": "{ifname} (No IP) пһ–",
        "format-disconnected": "у°Ө«",
        "format-alt": "{essid} | {ipaddr} {icon}",
        "format-icons": ["у°ӨҜ", "у°Өҹ", "у°Өў", "у°ӨҘ", "у°ӨЁ"]
    },
    "battery": {
        "interval": 2,
        "states": {
            "full": 100,
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% п—§",
        "format-alt": "{time} {icon}",
        "format-time": "{H}h {M}m",
        "format-full": "{icon}",
        "format-icons": ["пүғ", "пүӮ", "пүҒ", "пүҖ"],
        "tooltip-format": "Charged {capacity}%"
    }
}
